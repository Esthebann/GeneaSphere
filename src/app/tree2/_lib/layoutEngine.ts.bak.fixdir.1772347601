export type Mode = 'both' | 'ancestors' | 'descendants'

export type GraphNode = {
  id: string
  type: 'MEMBER' | 'UNION'
  label?: string
  sex?: string
  visibility?: string
  status?: string
}

export type GraphLink = {
  source: string
  target: string
  type: 'PARTNER' | 'CHILD'
  linkType?: 'BIOLOGICAL' | 'ADOPTED' | 'FOSTER' | string
}

export type Graph = {
  rootMemberId: string
  nodes: GraphNode[]
  links: GraphLink[]
}

export type Pos = { x: number; y: number }

export type LayoutOpts = {
  yGapGen: number
  xGapMember: number
  xGapChild: number
  coupleGap: number
  minGap: number
  maxIter?: number
}

const clamp = (n: number, a: number, b: number) => Math.max(a, Math.min(b, n))

function buildIndex(graph: Graph) {
  const nodeById = new Map<string, GraphNode>()
  for (const n of graph.nodes) nodeById.set(n.id, n)
  return nodeById
}

/**
 * Compute "generation layers" as integers.
 * Rules:
 * - PARTNER edges are same-generation (delta 0)
 * - CHILD edges: UNION -> MEMBER is +1 generation (child below union)
 *   and MEMBER -> UNION is -1 (to climb ancestors)
 */

function computeLayers(graph: Graph, focusId: string, mode: Mode) {
  const nodeById = buildIndex(graph)

  // --- 1) Indexer unions: partners / children
  const partnersByUnion = new Map<string, string[]>()
  const childrenByUnion = new Map<string, string[]>()

  for (const n of graph.nodes) {
    if (n.type === 'UNION') {
      partnersByUnion.set(n.id, [])
      childrenByUnion.set(n.id, [])
    }
  }

  for (const l of graph.links) {
    if (l.type === 'PARTNER') {
      const u = String(l.target) // API: MEMBER -> UNION
      const m = String(l.source)
      if (!partnersByUnion.has(u)) partnersByUnion.set(u, [])
      partnersByUnion.get(u)!.push(m)
    } else if (l.type === 'CHILD') {
      const u = String(l.source) // API: UNION -> MEMBER
      const c = String(l.target)
      if (!childrenByUnion.has(u)) childrenByUnion.set(u, [])
      childrenByUnion.get(u)!.push(c)
    }
  }

  // --- 2) Construire graphe MEMBER->MEMBER (parent->child) à partir des unions
  const kidsByParent = new Map<string, string[]>()
  const parentsByKid = new Map<string, string[]>()

  for (const n of graph.nodes) {
    if (n.type === 'MEMBER') {
      kidsByParent.set(n.id, [])
      parentsByKid.set(n.id, [])
    }
  }

  for (const [u, partners] of partnersByUnion.entries()) {
    const kids = childrenByUnion.get(u) || []
    for (const pId of partners) {
      if (!kidsByParent.has(pId)) kidsByParent.set(pId, [])
      for (const cId of kids) {
        kidsByParent.get(pId)!.push(cId)
        if (!parentsByKid.has(cId)) parentsByKid.set(cId, [])
        parentsByKid.get(cId)!.push(pId)
      }
    }
  }

  // --- 3) BFS couches sur MEMBERS uniquement
  const start = nodeById.has(focusId) ? focusId : graph.rootMemberId
  const layerMember = new Map<string, number>()
  layerMember.set(start, 0)

  const q = [start]
  const seen = new Set([start])

  const allowDir = (dir: 'down' | 'up') => {
    if (mode === 'both') return true
    if (mode === 'descendants') return dir === 'down'
    if (mode === 'ancestors') return dir === 'up'
    return true
  }

  while (q.length) {
    const cur = q.shift()!
    const curL = layerMember.get(cur)!
    // descendants
    if (allowDir('down')) {
      const kids = kidsByParent.get(cur) || []
      for (const k of kids) {
        if (!layerMember.has(k)) {
          layerMember.set(k, curL + 1)
          if (!seen.has(k)) { seen.add(k); q.push(k) }
        }
      }
    }
    // ancestors
    if (allowDir('up')) {
      const pars = parentsByKid.get(cur) || []
      for (const pId of pars) {
        if (!layerMember.has(pId)) {
          layerMember.set(pId, curL - 1)
          if (!seen.has(pId)) { seen.add(pId); q.push(pId) }
        }
      }
    }
  }

  // --- 4) Dériver layers UNION depuis layers partenaires (moyenne arrondie)
  const layer = new Map<string, number>()

  for (const n of graph.nodes) {
    if (n.type === 'MEMBER') {
      if (layerMember.has(n.id)) layer.set(n.id, layerMember.get(n.id)!)
    }
  }

  for (const [u, partners] of partnersByUnion.entries()) {
    const vals = partners
      .map(pid => layerMember.get(pid))
      .filter((v): v is number => typeof v === 'number')
    if (vals.length) {
      const avg = vals.reduce((a,b)=>a+b,0) / vals.length
      layer.set(u, Math.round(avg))
    }
  }

  // --- 5) Assurer CHILD: union->child ~ union+1 si child non défini
  for (const [u, kids] of childrenByUnion.entries()) {
    const lu = layer.get(u)
    if (typeof lu !== 'number') continue
    for (const cId of kids) {
      if (!layer.has(cId) && nodeById.get(cId)?.type === 'MEMBER') {
        layer.set(cId, lu + 1)
      }
    }
  }

  // --- 6) Remplir manquants (proches du focus)
  const base = layer.get(start) ?? 0
  for (const n of graph.nodes) {
    if (!layer.has(n.id)) layer.set(n.id, base)
  }

  // --- 7) Normaliser min layer = 0
  let minL = 0
  for (const v of layer.values()) minL = Math.min(minL, v)
  if (minL !== 0) {
    for (const [id, v] of layer.entries()) layer.set(id, v - minL)
  }

  return layer
}


/**
 * Build neighbor lists for ordering.
 * We only use directed "down edges" (generation edges) to reduce crossings.
 */
function buildDownNeighbors(graph: Graph, layer: Map<string, number>) {
  const down = new Map<string, string[]>()     // u -> children (next layer)
  const up = new Map<string, string[]>()       // v -> parents (prev layer)
  for (const n of graph.nodes) { down.set(n.id, []); up.set(n.id, []) }

  for (const l of graph.links) {
    if (l.type !== 'CHILD') continue
    const ls = layer.get(l.source) ?? 0
    const lt = layer.get(l.target) ?? 0
    if (lt === ls + 1) {
      down.get(l.source)!.push(l.target)
      up.get(l.target)!.push(l.source)
    }
  }
  return { down, up }
}

function median(nums: number[]) {
  if (nums.length === 0) return 0
  const a = [...nums].sort((x, y) => x - y)
  const mid = Math.floor(a.length / 2)
  return a.length % 2 ? a[mid] : (a[mid - 1] + a[mid]) / 2
}

function pack1D(ids: string[], x: Map<string, number>, minGap: number) {
  // ensure x[i+1] >= x[i] + minGap
  ids.sort((a, b) => (x.get(a) ?? 0) - (x.get(b) ?? 0))
  let cur = -Infinity
  for (const id of ids) {
    const xi = x.get(id) ?? 0
    if (xi < cur + minGap) x.set(id, cur + minGap)
    cur = x.get(id) ?? 0
  }
}

function centerLayer(ids: string[], x: Map<string, number>) {
  if (!ids.length) return
  const xs = ids.map(id => x.get(id) ?? 0)
  const avg = xs.reduce((a, b) => a + b, 0) / xs.length
  for (const id of ids) x.set(id, (x.get(id) ?? 0) - avg)
}

function enforceUnionCentering(graph: any, pos: Map<string, {x:number;y:number}>, coupleGap: number) {
  // Map unionId -> partnerIds
  const partnersByUnion = new Map<string, string[]>()
  for (const l of (graph.links || [])) {
    if (l.type !== 'PARTNER') continue
    const u = String(l.target)
    const p = String(l.source)
    const arr = partnersByUnion.get(u) || []
    arr.push(p)
    partnersByUnion.set(u, arr)
  }

  // For each union, set union.x = avg(partners.x); also nudge partners apart if too close
  for (const [u, partners] of partnersByUnion.entries()) {
    const up = pos.get(u)
    if (!up) continue
    const ps = partners.map(id => pos.get(id)).filter(Boolean) as Array<{x:number;y:number}>
    if (ps.length === 0) continue

    if (ps.length >= 2) {
      const a = pos.get(partners[0])
      const b = pos.get(partners[1])
      if (a && b) {
        const dx = Math.abs(a.x - b.x)
        if (dx < coupleGap) {
          const mid = (a.x + b.x) / 2
          a.x = mid - coupleGap / 2
          b.x = mid + coupleGap / 2
          pos.set(partners[0], a)
          pos.set(partners[1], b)
        }
      }
    }

    const ps2 = partners.map(id => pos.get(id)).filter(Boolean) as Array<{x:number;y:number}>
    const avgX = ps2.reduce((acc, p) => acc + p.x, 0) / ps2.length
    pos.set(u, { x: avgX, y: up.y })
  }
}

export function layoutStrict(
  graph: Graph,
  focusId: string,
  mode: Mode,
  opts: LayoutOpts
): Map<string, Pos> {
  const { yGapGen, xGapMember, xGapChild, coupleGap, minGap } = opts
  const maxIter = opts.maxIter ?? 6

  const nodeById = buildIndex(graph)
  const layer = computeLayers(graph, focusId, mode)

  // Group nodes by layer
  const layers = new Map<number, string[]>()
  let maxL = 0
  for (const n of graph.nodes) {
    const l = layer.get(n.id) ?? 0
    maxL = Math.max(maxL, l)
    if (!layers.has(l)) layers.set(l, [])
    layers.get(l)!.push(n.id)
  }

  // Init x by order in layer
  const x = new Map<string, number>()
  for (const [l, ids] of layers.entries()) {
    ids.sort((a, b) => a.localeCompare(b))
    ids.forEach((id, i) => {
      const n = nodeById.get(id)
      const gap = n?.type === 'UNION' ? coupleGap : xGapMember
      x.set(id, i * gap)
    })
    centerLayer(ids, x)
  }

  const { down, up } = buildDownNeighbors(graph, layer)

  // Iterative crossing reduction: top-down + bottom-up (bary/median)
  for (let iter = 0; iter < maxIter; iter++) {
    // top-down: order layer k by median of parents in k-1
    for (let l = 1; l <= maxL; l++) {
      const ids = layers.get(l) || []
      const prev = layers.get(l - 1) || []
      const idxPrev = new Map<string, number>()
      prev.sort((a, b) => (x.get(a) ?? 0) - (x.get(b) ?? 0))
      prev.forEach((id, i) => idxPrev.set(id, i))

      const score = new Map<string, number>()
      for (const id of ids) {
        const parents = up.get(id) || []
        const nums = parents.map(p => idxPrev.get(p)).filter((v): v is number => typeof v === 'number')
        score.set(id, median(nums))
      }
      ids.sort((a, b) => (score.get(a) ?? 0) - (score.get(b) ?? 0))
      // assign provisional x and pack
      ids.forEach((id, i) => {
        const n = nodeById.get(id)
        const gap = n?.type === 'UNION' ? coupleGap : xGapChild
        x.set(id, i * gap)
      })
      pack1D(ids, x, minGap)
      centerLayer(ids, x)
      layers.set(l, ids)
    }

    // bottom-up: order layer k by median of children in k+1
    for (let l = maxL - 1; l >= 0; l--) {
      const ids = layers.get(l) || []
      const next = layers.get(l + 1) || []
      const idxNext = new Map<string, number>()
      next.sort((a, b) => (x.get(a) ?? 0) - (x.get(b) ?? 0))
      next.forEach((id, i) => idxNext.set(id, i))

      const score = new Map<string, number>()
      for (const id of ids) {
        const kids = down.get(id) || []
        const nums = kids.map(c => idxNext.get(c)).filter((v): v is number => typeof v === 'number')
        score.set(id, median(nums))
      }
      ids.sort((a, b) => (score.get(a) ?? 0) - (score.get(b) ?? 0))
      ids.forEach((id, i) => {
        const n = nodeById.get(id)
        const gap = n?.type === 'UNION' ? coupleGap : xGapMember
        x.set(id, i * gap)
      })
      pack1D(ids, x, minGap)
      centerLayer(ids, x)
      layers.set(l, ids)
    }
  }

  // Build final positions
  const pos = new Map<string, Pos>()
  for (const n of graph.nodes) {
    const l = layer.get(n.id) ?? 0
    pos.set(n.id, { x: x.get(n.id) ?? 0, y: l * yGapGen })
  }

  // Center focus at (0,0)
  const f = pos.get(focusId) || pos.get(graph.rootMemberId)
  if (f) {
    for (const [id, p] of pos.entries()) {
      pos.set(id, { x: p.x - f.x, y: p.y - f.y })
    }
  }

  return pos
}
